# Optional public URLs (embedded at build time). Copy to `.env.local` and fill in.

# Profile links (https://...)
VITE_GITHUB_URL=
VITE_LINKEDIN_URL=

# Contact: used by the Comms page mailto button (plain email, no mailto: prefix)
VITE_EMAIL=

# Direct link to your résumé PDF or hosted CV (https://...)
VITE_RESUME_URL=

# Firebase Web app (optional). From Firebase Console → Project settings → Your apps → SDK snippet.
# Safe to expose in the client; security is Firestore/Storage rules + Auth settings, not hiding these.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional; enables Analytics when supported in the browser
VITE_FIREBASE_MEASUREMENT_ID=
