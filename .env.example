# Optional public URLs (embedded at build time). Copy to `.env.local` and fill in.

# Profile links (https://...)
VITE_GITHUB_URL=
VITE_LINKEDIN_URL=

# Résumé: optional override — full https URL or same-site path (e.g. /cv.pdf).
# If unset, the app links to /resume.pdf (place your file at public/resume.pdf).
VITE_RESUME_URL=

# Firebase Web app (optional). From Firebase Console → Project settings → Your apps → SDK snippet.
# Safe to expose in the client; security is Firestore/Storage rules + Auth settings, not hiding these.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional; enables Analytics when supported in the browser
VITE_FIREBASE_MEASUREMENT_ID=

# --- Secure contact form (/comms) ---
# Client (build-time): Turnstile site key (public). Required on the client if the server enforces Turnstile.
VITE_TURNSTILE_SITE_KEY=
# Optional: full URL if the API is not same-origin (default POST /api/contact).
# VITE_CONTACT_API_URL=
# Local dev: Vite proxies /api/contact → this origin. Run in another terminal: npm run pages:dev
VITE_DEV_CONTACT_API_PROXY=http://127.0.0.1:8788
# For wrangler, copy server vars into a gitignored file `.dev.vars` (KEY=value per line); see Cloudflare Pages local dev docs.

# Server-only — set in Cloudflare Pages → Settings → Environment variables (Functions), NOT in Vite.
# Do NOT prefix with VITE_ (those ship to the browser).
#
# RESEND_API_KEY=re_...          # https://resend.com/api-keys
# CONTACT_TO_EMAIL=you@domain.com
# CONTACT_FROM=Portfolio <mail@yourdomain.com>   # optional; must be a verified sender/domain in Resend
# TURNSTILE_SECRET=0x...         # Pair with VITE_TURNSTILE_SITE_KEY
# CONTACT_REQUIRE_TURNSTILE=true # Production: require Turnstile + secret (blocks simple script bots without a token)
# CONTACT_ALLOWED_COUNTRIES=US  # Comma-separated ISO codes; US-only when set to US. Omit for local wrangler (no cf.country).
# ALLOWED_ORIGINS=https://yoursite.pages.dev,https://yoursite.com   # recommended in production
#
# KV binding CONTACT_RATE_LIMIT strongly recommended: 3 submits / minute / IP, 6 / hour / IP (burst + flood control).
# Layered DDoS: Cloudflare dashboard → Security → WAF / Bots; add a rate-limiting rule for POST /api/contact on your zone.
